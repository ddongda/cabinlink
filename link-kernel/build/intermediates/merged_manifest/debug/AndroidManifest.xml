<?xml version="1.0" encoding="utf-8"?>
<!--
 量产版需补：android:sharedUserId="android.uid.system" + persistent + signature 权限。
     最小骨架为可直接安装验证，暂不加（见 code-landmarks 冻结区说明）。
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.baic.cabinlink.kernel"
    android:versionCode="1"
    android:versionName="0.1.0" >

    <uses-sdk
        android:minSdkVersion="28"
        android:targetSdkVersion="34" />

    <application
        android:allowBackup="false"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:label="CabinLink Kernel" >
        <service
            android:name="com.baic.cabinlink.kernel.LinkKernelService"
            android:exported="true" >
            <intent-filter>
                <action android:name="com.baic.cabinlink.BIND_KERNEL" />
            </intent-filter>
        </service>
    </application>

</manifest>