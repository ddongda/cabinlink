<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.baic.usercenter"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="28"
        android:targetSdkVersion="34" />

    <permission
        android:name="com.baic.bridge.permission.LINK"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.baic.bridge.permission.LINK" />

    <application
        android:name="com.baic.usercenter.UsercenterApp"
        android:allowBackup="false"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:label="用户中心(账号Provider)" >

        <!-- 模拟"宿主已有 Service"：加一个 Bridge action 复用同一 Service 暴露通道，不新增 Service 类 -->
        <service
            android:name="com.baic.usercenter.HostService"
            android:exported="true"
            android:permission="com.baic.bridge.permission.LINK" >
            <intent-filter>
                <action android:name="com.baic.usercenter.HOST" />
            </intent-filter>
        </service>

        <activity
            android:name="com.baic.usercenter.MainActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>