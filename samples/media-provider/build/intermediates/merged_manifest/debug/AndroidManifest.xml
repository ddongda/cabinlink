<?xml version="1.0" encoding="utf-8"?>
<!-- 全量形态：BridgeNodeService 由 core:full 的 aar manifest 自动合并（含 action + signature 权限），此处无需声明 Service。 -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.baic.media"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="28"
        android:targetSdkVersion="34" />

    <permission
        android:name="com.baic.bridge.permission.LINK"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.baic.bridge.permission.LINK" />

    <application
        android:name="com.baic.media.MediaApp"
        android:allowBackup="false"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:label="多媒体(Provider)" >
        <activity
            android:name="com.baic.media.MainActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="com.baic.bridge.core.full.BridgeNodeService"
            android:exported="true"
            android:permission="com.baic.bridge.permission.LINK" >
            <intent-filter>
                <action android:name="com.baic.bridge.NODE" />
            </intent-filter>
        </service>
    </application>

</manifest>