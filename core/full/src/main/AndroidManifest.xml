<?xml version="1.0" encoding="utf-8"?>
<!-- 托管 Service 随 aar 合并进宿主，全量形态业务无需自己声明 Service。
     Service 加 android:permission（signature 级）做 ACL：只有同签名 App 能 bind。 -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <service
            android:name="com.baic.bridge.core.full.BridgeNodeService"
            android:exported="true"
            android:permission="com.baic.bridge.permission.LINK">
            <intent-filter>
                <action android:name="com.baic.bridge.NODE" />
            </intent-filter>
        </service>
    </application>
</manifest>
