<?xml version="1.0" encoding="utf-8"?>
<!-- 定义并声明使用 Bridge 互连权限（signature 级）：只有同签名 App 才能 bind 彼此的节点 Service。
     该权限随 core:lite 合并进每个依赖方；被 bind 的 Service 须加 android:permission 引用它。 -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <permission
        android:name="com.baic.bridge.permission.LINK"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.baic.bridge.permission.LINK" />

</manifest>
